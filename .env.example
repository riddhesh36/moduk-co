# .env.local
# This file connects your local Next.js environment to your live Supabase database.
# Find these keys in your Supabase Dashboard: Project Settings > API

# Your Project URL (e.g. https://your-project-ref.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Your Project anon/public API key (e.g. eyJhbGciOiJIUzI1NiIsIn...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Credentials
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Supabase Service Role Key (for webhooks/backend order confirmations bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
